<!-- File: views/articles/list.ejs -->
<div class="flex justify-between items-center mb-6">
  <h2 class="text-3xl font-bold text-gray-800"><%= title %></h2>
  <div class="flex gap-3">
    
    <a href="/admin/pages/new" class="btn-primary">
      <svg class="w-5 h-5 inline-block mr-2 -mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Add Page
    </a>
   
  </div>
</div>

<!-- Filter Section -->
<div class="bg-white rounded-2xl shadow-lg p-6 mb-6 border border-gray-200">
  <h3 class="text-lg font-semibold text-gray-800 mb-4">Filters</h3>
  <form method="GET" action="/admin/pages">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-4">
      <input 
        type="text" 
        name="q" 
        placeholder="Search title..." 
        value="<%= filters.q %>"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
      />
      <select 
        name="status"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
      >
        <option value="">All Status</option>
        <option value="Draft" <%= filters.status === 'Draft' ? 'selected' : '' %>>Draft</option>
        <option value="Active" <%= filters.status === 'Active' ? 'selected' : '' %>>Active</option>
        <option value="InActive" <%= filters.status === 'InActive' ? 'selected' : '' %>>InActive</option>
      </select>
      
      <button type="submit" class="btn-primary">
        <svg class="w-5 h-5 inline-block mr-2 -mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Filter
      </button>

    </div>
  </div>

  <!-- Stats Cards -->
  <div class="stats-mini-grid">
    <div class="stat-mini-card">
      <div class="stat-mini-icon stat-mini-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
        </svg>
      </div>
      <div class="stat-mini-content">
        <span class="stat-mini-label">Total Pages</span>
        <span class="stat-mini-value"><%= articles?.length || 0 %></span>
      </div>
    </div>
    <div class="stat-mini-card">
      <div class="stat-mini-icon stat-mini-green">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <div class="stat-mini-content">
        <span class="stat-mini-label">Active</span>
        <span class="stat-mini-value"><%= articles?.filter(a => a.status === 'Active').length || 0 %></span>
      </div>
    </div>
    <div class="stat-mini-card">
      <div class="stat-mini-icon stat-mini-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"></path>
          <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
        </svg>
      </div>
      <div class="stat-mini-content">
        <span class="stat-mini-label">Draft</span>
        <span class="stat-mini-value"><%= articles?.filter(a => a.status === 'Draft').length || 0 %></span>
      </div>
    </div>
  </div>

  <!-- Table Card -->
  <div class="table-card">
    <div class="table-card-header">
      <div class="table-card-title">
        <h3>All Pages</h3>
        <span class="table-card-count"><%= articles?.length || 0 %> total</span>
      </div>
    </div>

    <div class="table-wrapper">
      <table class="modern-table">
        <thead>
          <tr>
            <th class="checkbox-col">
              <label class="custom-checkbox">
                <input type="checkbox" id="selectAll" />
                <span class="checkmark"></span>
              </label>
            </th>
            <th class="sortable">
              Title
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="7 10 12 15 17 10"></polyline>
                <polyline points="7 14 12 9 17 14"></polyline>
              </svg>
            </th>
            <th>Sub Title</th>
            <th>Slug</th>
            <th class="sortable">
              Status
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="7 10 12 15 17 10"></polyline>
                <polyline points="7 14 12 9 17 14"></polyline>
              </svg>
            </th>
            <th class="action-col">Actions</th>
          </tr>
        </thead>
        <tbody id="categoryTableBody">
          <% if (articles && articles.length > 0) { %>
            <% articles.forEach((article, index) => { %>
            <tr class="table-row" style="animation-delay: <%= index * 0.05 %>s">
              <td class="checkbox-col">
                <label class="custom-checkbox">
                  <input type="checkbox" class="row-checkbox" />
                  <span class="checkmark"></span>
                </label>
              </td>
              <td class="category-name-col">
                <div class="category-info">
                  <div class="category-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                  </div>
                  <span class="category-name"><%= article.name %></span>
                </div>
              </td>
              <td>
                <span class="parent-category-badge"><%= article.sanskritTitle || '' %></span>
              </td>
              <td>
                <span class="parent-category-badge"><%= article.slug || '' %></span>
              </td>
              <td>
                <% if (article.status === 'Active') { %>
                  <span class="status-badge status-active">
                    <span class="status-dot"></span>
                    Active
                  </span>
                <% } else if (article.status === 'InActive') { %>
                  <span class="status-badge status-inactive">
                    <span class="status-dot"></span>
                    InActive
                  </span>
                <% } else { %>
                  <span class="status-badge status-draft">
                    <span class="status-dot"></span>
                    Draft
                  </span>
                <% } %>
              </td>
              <td class="action-col">
                <div class="action-buttons">
                  <a href="/admin/pages/edit/<%= article.id %>" class="btn-icon btn-edit" title="Edit">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 20h9"></path>
                      <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                    </svg>
                  </a>
                  <form method="POST" action="/admin/pages/toggle-status/<%= article.id %>" class="inline-form">
                    <button type="submit" class="btn-icon btn-toggle" title="Toggle Status">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M12 1v6m0 6v6"></path>
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="empty-state">
                <div class="empty-state-content">
                  <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                  </svg>
                  <h3>No articles found</h3>
                  <p>Try adjusting your filters or create a new article</p>
                  <a href="/admin/pages/new" class="action-btn action-btn-primary" style="margin-top: 15px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Create First Page
                  </a>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <% if (articles && articles.length > 0 && pagination && pagination.totalPages > 1) { %>
  <div class="pagination-wrapper">
    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <a 
        href="?page=<%= i %>&<%= new URLSearchParams(filters).toString() %>"
        class="pagination-btn <%= i === pagination.page ? 'active' : '' %>"
      >
        <%= i %>
      </a>
    <% } %>
  </div>
  <% } %>
</div>

<script>
  // Select all checkbox
  const selectAll = document.getElementById('selectAll');
  if (selectAll) {
    selectAll.addEventListener('change', function() {
      const checkboxes = document.querySelectorAll('.row-checkbox');
      checkboxes.forEach(cb => cb.checked = this.checked);
    });
  }
</script>
