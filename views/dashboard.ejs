<h2>Dashboard Overview</h2>
<ul>
  <li>Total Users: <%= stats.userCount %></li>
  <li>Total Articles: <%= stats.articleCount %></li>
  <li>Total Categories: <%= stats.categoryCount %></li>
  <li>Total Sub-Categories: <%= stats.subCategoryCount %></li>
</ul>

<canvas id="statusChart" width="400" height="200"></canvas>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const ctx = document.getElementById('statusChart').getContext('2d');
    const chart = new Chart(ctx, {
      type: 'pie',
      data: {
        labels: <%= JSON.stringify(stats.statusStats.map(s => s.status)) %>,
        datasets: [{
          data: <%= JSON.stringify(stats.statusStats.map(s => s.count)) %>,
          backgroundColor: ['#36A2EB', '#FF6384']
        }]
      }
    });
  });
</script>
