<!-- File: views/subcategories/form.ejs -->
<h2><%= subcategory ? 'Edit' : 'Create' %> Sub-Category: <%= subcategory ? subcategory.name : '' %></h2>
<form method="POST" action="/admin/subcategories/save" enctype="multipart/form-data">
  <% if (subcategory) { %>
    <input type="hidden" name="id" value="<%= subcategory.id %>">
  <% } %>
  <div class="mb-3">
    <label class="form-label">Name:</label>
    <input type="text" class="form-control" name="name" value="<%= subcategory ? subcategory.name : '' %>" required>
  </div>
  <div class="mb-3">
    <label class="form-label">Slug:</label>
    <input
      class="form-control"
      type="text"
      name="slug"
      value="<%= subcategory ? subcategory.slug : '' %>"
    />
  </div>
  <div class="mb-3">
  <label class="form-label">Category:</label>
  <select class="form-control" name="categoryId" required>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.id %>" <%= subcategory && subcategory.categoryId === cat.id ? 'selected' : '' %>>
        <%= cat.name %>
      </option>
    <% }) %>
  </select>
  </div>
  <div class="mb-3">
    <label class="form-label">Image:</label>
    <input
      class="form-control"
      type="file"
      name="image"
      value="<%= subcategory ? subcategory.image : '' %>"
    />
  </div>
  <div class="mb-3">
    <label class="form-label">Short Description:</label>
    <textarea
      name="shortDescription"
      id="shortDescription"
      class="form-control"
      rows="4"
    >
    <%= subcategory?.shortDescription || '' %></textarea
    >
  </div>
  <div class="mb-3">
    <label class="form-label">Full Description:</label>
    <textarea
      name="fullDescription"
      id="fullDescription"
      class="form-control"
      rows="4"
    >
    <%= subcategory ? subcategory.fullDescription || '' : '' %></textarea
    >
  </div>
  <div class="mb-3">
    <label class="form-label">Meta Title:</label>
    <input
      class="form-control"
      type="text"
      name="metaTitle"
      value="<%= subcategory ? subcategory.metaTitle : '' %>"
    />
  </div>
  <div class="mb-3">
    <label class="form-label">Meta Description:</label>
    <textarea
      name="metaDescription"
      id="metaDescription"
      class="form-control"
      rows="4"
    >
<%= subcategory?.metaDescription || '' %></textarea
    >
  </div>
  <div class="mb-3">
    <label class="form-label">Meta Keywords:</label>
    <input
      class="form-control"
      type="text"
      name="metaKeywords"
      value="<%= subcategory ? subcategory.metaKeywords : '' %>"
    />
  </div>
  <div class="mb-3">
    <label class="form-label">OG Title:</label>
    <input
      class="form-control"
      type="text"
      name="ogTitle"
      value="<%= subcategory ? subcategory.ogTitle : '' %>"
    />
  </div>
  <div class="mb-3">
    <label class="form-label">OG Description:</label>
    <textarea
      name="ogDescription"
      id="ogDescription"
      class="form-control"
      rows="4"
    >
<%= subcategory?.ogDescription || '' %></textarea
    >
  </div>
  <div class="mb-3">
    <label class="form-label">OG IMage:</label>
    <input
      class="form-control"
      type="file"
      name="ogImage"
      value="<%= subcategory ? subcategory.ogImage : '' %>"
    />
  </div>
  <div class="mb-3">
    <label class="form-label">Canonical URL:</label>
    <input
      class="form-control"
      type="text"
      name="canonicalUrl"
      value="<%= subcategory ? subcategory.canonicalUrl : '' %>"
    />
  </div>
  <div class="mb-3">
    <label class="form-label">Schema Type:</label>
    <input
      class="form-control"
      type="text"
      name="schemaType"
      value="<%= subcategory ? subcategory.schemaType : '' %>"
    />
  </div>
  <div class="mb-3">
    <label class="form-label">Status:</label>
    <select name="status" id="status" class="form-control">
      <option value="Active" selected>Active</option>
      <option value="Draft" selected>Draft</option>
      <option value="Inactive" selected>Inactive</option>
    </select>
  </div>

  <button type="submit" class="btn btn-primary">Save</button>
</form>

<script>
  ClassicEditor.create(document.querySelector("#shortDescription")).catch(
    (error) => {
      console.error(error);
    }
  );
  ClassicEditor.create(document.querySelector("#fullDescription")).catch(
    (error) => {
      console.error(error);
    }
  );
  ClassicEditor.create(document.querySelector("#metaDescription")).catch(
    (error) => {
      console.error(error);
    }
  );
  ClassicEditor.create(document.querySelector("#ogDescription")).catch(
    (error) => {
      console.error(error);
    }
  );
</script>