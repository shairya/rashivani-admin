<!-- File: views/subcategories/form.ejs -->
<div class="form-page-wrapper">
  <!-- Page Header -->
  <div class="form-page-header">
    <div>
      <h1 class="form-page-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
          <line x1="12" y1="11" x2="12" y2="17"></line>
          <line x1="9" y1="14" x2="15" y2="14"></line>
        </svg>
        <%= subcategory ? 'Edit' : 'Create' %> Sub-Category
      </h1>
      <p class="form-page-subtitle">Fill in the details below to <%= subcategory ? 'update' : 'create' %> your sub-category</p>
    </div>
    <a href="/admin/subcategories" class="action-btn action-btn-secondary">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to List
    </a>
  </div>

  <form method="POST" action="/admin/subcategories/save" enctype="multipart/form-data" class="article-form">
    <% if (subcategory) { %>
    <input type="hidden" name="id" value="<%= subcategory.id %>" />
    <% } %>

    <!-- Basic Information -->
    <div class="form-section-card">
      <div class="form-section-header header-green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <h2>Basic Information</h2>
      </div>
      <div class="form-section-body">
        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>Name <span class="required">*</span></label>
            <input type="text" name="name" value="<%= subcategory ? subcategory.name : '' %>" required class="form-input-modern" placeholder="Enter sub-category name" />
          </div>
          <div class="form-group-modern">
            <label>Slug</label>
            <input type="text" name="slug" value="<%= subcategory ? subcategory.slug : '' %>" class="form-input-modern" placeholder="auto-generated-slug" />
          </div>
        </div>

        <div class="form-grid-3">
          <div class="form-group-modern">
            <label>Parent Category <span class="required">*</span></label>
            <select name="categoryId" required class="form-input-modern">
              <option value="">Select Category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>" <%= subcategory && subcategory.categoryId === cat.id ? 'selected' : '' %>><%= cat.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group-modern">
            <label>Sub-Category Image</label>
            <input type="file" name="image" accept="image/*" class="form-input-modern file-input" />
            <% if (subcategory && subcategory.image) { %>
            <div class="image-preview">
              <img src="<%= subcategory.image %>" alt="Current image" />
            </div>
            <% } %>
          </div>
          <div class="form-group-modern">
            <label>Status</label>
            <select name="status" class="form-input-modern">
              <option value="Active" <%= subcategory && subcategory.status === 'Active' ? 'selected' : '' %>>✅ Active</option>
              <option value="Draft" <%= !subcategory || subcategory.status === 'Draft' ? 'selected' : '' %>>📝 Draft</option>
              <option value="Inactive" <%= subcategory && subcategory.status === 'Inactive' ? 'selected' : '' %>>⭕ Inactive</option>
            </select>
          </div>
        </div>
      </div>
    </div>

    <!-- Content Section -->
    <div class="form-section-card">
      <div class="form-section-header header-purple">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
        </svg>
        <h2>Content</h2>
      </div>
      <div class="form-section-body">
        <div class="form-group-modern">
          <label>Short Description</label>
          <textarea name="shortDescription" id="shortDescription" rows="4" class="form-input-modern" placeholder="Enter a brief description..."><%= subcategory?.shortDescription || '' %></textarea>
        </div>
        <div class="form-group-modern">
          <label>Full Description</label>
          <textarea name="fullDescription" id="fullDescription" rows="6" class="form-input-modern" placeholder="Enter detailed description..."><%= subcategory ? subcategory.fullDescription || '' : '' %></textarea>
        </div>
      </div>
    </div>

    <!-- SEO Meta Tags -->
    <div class="form-section-card">
      <div class="form-section-header header-teal">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <h2>SEO Meta Tags</h2>
      </div>
      <div class="form-section-body">
        <div class="form-group-modern">
          <label>Meta Title</label>
          <input type="text" name="metaTitle" value="<%= subcategory ? subcategory.metaTitle : '' %>" maxlength="60" class="form-input-modern" placeholder="Recommended: 50-60 characters" />
          <span class="field-hint">Optimal length: 50-60 characters</span>
        </div>
        <div class="form-group-modern">
          <label>Meta Description</label>
          <textarea name="metaDescription" id="metaDescription" rows="3" maxlength="160" class="form-input-modern" placeholder="Recommended: 150-160 characters"><%= subcategory?.metaDescription || '' %></textarea>
          <span class="field-hint">Optimal length: 150-160 characters</span>
        </div>
        <div class="form-group-modern">
          <label>Meta Keywords</label>
          <input type="text" name="metaKeywords" value="<%= subcategory ? subcategory.metaKeywords : '' %>" class="form-input-modern" placeholder="keyword1, keyword2, keyword3" />
          <span class="field-hint">Separate keywords with commas</span>
        </div>
      </div>
    </div>

    <!-- Open Graph Tags -->
    <div class="form-section-card">
      <div class="form-section-header header-rose">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
        <h2>Open Graph (Social Media)</h2>
      </div>
      <div class="form-section-body">
        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>OG Title</label>
            <input type="text" name="ogTitle" value="<%= subcategory ? subcategory.ogTitle : '' %>" class="form-input-modern" placeholder="Title for social media sharing" />
          </div>
          <div class="form-group-modern">
            <label>OG Image</label>
            <input type="file" name="ogImage" accept="image/*" class="form-input-modern file-input" />
            <% if (subcategory && subcategory.ogImage) { %>
            <div class="image-preview">
              <img src="<%= subcategory.ogImage %>" alt="Current OG image" />
            </div>
            <% } %>
          </div>
        </div>
        <div class="form-group-modern">
          <label>OG Description</label>
          <textarea name="ogDescription" id="ogDescription" rows="3" class="form-input-modern" placeholder="Description for social media sharing"><%= subcategory?.ogDescription || '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Advanced SEO -->
    <div class="form-section-card">
      <div class="form-section-header header-indigo">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
        <h2>Advanced SEO</h2>
      </div>
      <div class="form-section-body">
        <div class="form-group-modern">
          <label>Canonical URL</label>
          <input type="text" name="canonicalUrl" value="<%= subcategory ? subcategory.canonicalUrl : '' %>" class="form-input-modern" placeholder="https://example.com/subcategory-name" />
          <span class="field-hint">Specify the preferred URL for this sub-category</span>
        </div>
        <div class="form-group-modern">
          <label>Schema Type</label>
          <textarea name="schemaType" id="schemaType" rows="3" class="form-input-modern" placeholder="e.g., CollectionPage, ItemList"><%= subcategory ? subcategory.schemaType : '' %></textarea>
          <span class="field-hint">Schema.org markup type for structured data</span>
        </div>
      </div>
    </div>

    <!-- Submit Actions -->
    <div class="form-actions-sticky">
      <a href="/admin/subcategories" class="action-btn action-btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Cancel
      </a>
      <button type="submit" class="action-btn action-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <%= subcategory ? 'Update' : 'Create' %> Sub-Category
      </button>
    </div>
  </form>
</div>

<script>
  // Initialize CKEditor
  ClassicEditor.create(document.querySelector("#shortDescription"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', '|', 'undo', 'redo']
  }).catch((error) => console.error(error));
  
  ClassicEditor.create(document.querySelector("#fullDescription"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
  }).catch((error) => console.error(error));

  ClassicEditor.create(document.querySelector("#metaDescription"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
  }).catch((error) => console.error(error));

  ClassicEditor.create(document.querySelector("#ogDescription"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
  }).catch((error) => console.error(error));

  ClassicEditor.create(document.querySelector("#schemaType"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
  }).catch((error) => console.error(error));
  
  // Auto-generate slug
  document.querySelector('input[name="name"]').addEventListener('input', function(e) {
    const slugField = document.querySelector('input[name="slug"]');
    if (!slugField.value || slugField.dataset.auto !== 'false') {
      const slug = e.target.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      slugField.value = slug;
      slugField.dataset.auto = 'true';
    }

    const canonicalUrlField = document.querySelector('input[name="canonicalUrl"]');
    const s = e.target.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    canonicalUrlField.value = 'https://www.rashivani.com/' + s;
    canonicalUrlField.dataset.auto = 'true';
  });
  
  document.querySelector('input[name="slug"]').addEventListener('input', function() {
    this.dataset.auto = 'false';
  });
  document.querySelector('input[name="canonicalUrl"]').addEventListener('input', function() {
    this.dataset.auto = 'false';
  });
</script>
