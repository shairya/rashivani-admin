<!-- File: views/subcategories/form.ejs -->
<div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">
        <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
          <%= subcategory ? 'Edit' : 'Create' %> Sub-Category
        </span>
      </h1>
      <p class="text-gray-600">Fill in the details below to <%= subcategory ? 'update' : 'create' %> your sub-category</p>
    </div>

    <form
      method="POST"
      action="/admin/subcategories/save"
      enctype="multipart/form-data"
      class="space-y-6"
    >
      <% if (subcategory) { %>
      <input type="hidden" name="id" value="<%= subcategory.id %>" />
      <% } %>

      <!-- Basic Information Card -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 px-6 py-4">
          <h2 class="text-xl font-semibold text-white flex items-center">
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Basic Information
          </h2>
        </div>
        <div class="p-6 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">
                Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                name="name"
                value="<%= subcategory ? subcategory.name : '' %>"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 outline-none hover:border-blue-400"
                placeholder="Enter sub-category name"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Slug</label>
              <input
                type="text"
                name="slug"
                value="<%= subcategory ? subcategory.slug : '' %>"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 outline-none hover:border-blue-400"
                placeholder="auto-generated-slug"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">
                Parent Category <span class="text-red-500">*</span>
              </label>
              <select
                name="categoryId"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 outline-none hover:border-blue-400 appearance-none bg-white"
              >
                <option value="">Select Category</option>
                <% categories.forEach(cat => { %>
                  <option value="<%= cat.id %>" <%= subcategory && subcategory.categoryId === cat.id ? 'selected' : '' %>>
                    <%= cat.name %>
                  </option>
                <% }) %>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Sub-Category Image</label>
              <input
                type="file"
                name="image"
                accept="image/*"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 outline-none hover:border-blue-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
              />
              <% if (subcategory && subcategory.image) { %>
              <div class="mt-2">
                <img src="<%= subcategory.image %>" alt="Current image" class="h-20 w-20 object-cover rounded-lg border border-gray-200">
              </div>
              <% } %>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Status</label>
              <select
                name="status"
                id="status"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 outline-none hover:border-blue-400 appearance-none bg-white"
              >
                <option value="Active" <%= subcategory && subcategory.status === 'Active' ? 'selected' : '' %>>🟢 Active</option>
                <option value="Draft" <%= !subcategory || subcategory.status === 'Draft' ? 'selected' : '' %>>📝 Draft</option>
                <option value="Inactive" <%= subcategory && subcategory.status === 'Inactive' ? 'selected' : '' %>>⭕ Inactive</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Content Section Card -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="bg-gradient-to-r from-purple-600 to-purple-700 px-6 py-4">
          <h2 class="text-xl font-semibold text-white flex items-center">
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            Content
          </h2>
        </div>
        <div class="p-6 space-y-6">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Short Description</label>
            <textarea
              name="shortDescription"
              id="shortDescription"
              rows="4"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200 outline-none hover:border-purple-400"
              placeholder="Enter a brief description..."
            ><%= subcategory?.shortDescription || '' %></textarea>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Full Description</label>
            <textarea
              name="fullDescription"
              id="fullDescription"
              rows="6"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent transition-all duration-200 outline-none hover:border-purple-400"
              placeholder="Enter detailed description..."
            ><%= subcategory ? subcategory.fullDescription || '' : '' %></textarea>
          </div>
        </div>
      </div>

      <!-- SEO Meta Tags Card -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="bg-gradient-to-r from-green-600 to-green-700 px-6 py-4">
          <h2 class="text-xl font-semibold text-white flex items-center">
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            SEO Meta Tags
          </h2>
        </div>
        <div class="p-6 space-y-6">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Meta Title</label>
            <input
              type="text"
              name="metaTitle"
              value="<%= subcategory ? subcategory.metaTitle : '' %>"
              maxlength="60"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 outline-none hover:border-green-400"
              placeholder="Recommended: 50-60 characters"
            />
            <p class="text-xs text-gray-500 mt-1">Optimal length: 50-60 characters</p>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Meta Description</label>
            <textarea
              name="metaDescription"
              id="metaDescription"
              rows="3"
              maxlength="160"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 outline-none hover:border-green-400"
              placeholder="Recommended: 150-160 characters"
            ><%= subcategory?.metaDescription || '' %></textarea>
            <p class="text-xs text-gray-500 mt-1">Optimal length: 150-160 characters</p>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Meta Keywords</label>
            <input
              type="text"
              name="metaKeywords"
              value="<%= subcategory ? subcategory.metaKeywords : '' %>"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-transparent transition-all duration-200 outline-none hover:border-green-400"
              placeholder="keyword1, keyword2, keyword3"
            />
            <p class="text-xs text-gray-500 mt-1">Separate keywords with commas</p>
          </div>
        </div>
      </div>

      <!-- Open Graph Tags Card -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="bg-gradient-to-r from-pink-600 to-pink-700 px-6 py-4">
          <h2 class="text-xl font-semibold text-white flex items-center">
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
            </svg>
            Open Graph (Social Media)
          </h2>
        </div>
        <div class="p-6 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">OG Title</label>
              <input
                type="text"
                name="ogTitle"
                value="<%= subcategory ? subcategory.ogTitle : '' %>"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition-all duration-200 outline-none hover:border-pink-400"
                placeholder="Title for social media sharing"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">OG Image</label>
              <input
                type="file"
                name="ogImage"
                accept="image/*"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition-all duration-200 outline-none hover:border-pink-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100"
              />
              <% if (subcategory && subcategory.ogImage) { %>
              <div class="mt-2">
                <img src="<%= subcategory.ogImage %>" alt="Current OG image" class="h-20 w-20 object-cover rounded-lg border border-gray-200">
              </div>
              <% } %>
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">OG Description</label>
            <textarea
              name="ogDescription"
              id="ogDescription"
              rows="3"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition-all duration-200 outline-none hover:border-pink-400"
              placeholder="Description for social media sharing"
            ><%= subcategory?.ogDescription || '' %></textarea>
          </div>
        </div>
      </div>

      <!-- Advanced SEO Card -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-6 py-4">
          <h2 class="text-xl font-semibold text-white flex items-center">
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Advanced SEO
          </h2>
        </div>
        <div class="p-6 space-y-6">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Canonical URL</label>
            <input
              type="text"
              name="canonicalUrl"
              value="<%= subcategory ? subcategory.canonicalUrl : '' %>"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 outline-none hover:border-indigo-400"
              placeholder="https://example.com/subcategory-name"
            />
            <p class="text-xs text-gray-500 mt-1">Specify the preferred URL for this sub-category</p>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Schema Type</label>
            <textarea
              type="text"
              name="schemaType"
              id="schemaType"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 outline-none hover:border-indigo-400"
              placeholder="e.g., CollectionPage, ItemList"
            ><%= subcategory ? subcategory.schemaType : '' %></textarea>
            <p class="text-xs text-gray-500 mt-1">Schema.org markup type for structured data</p>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex items-center justify-between bg-white rounded-2xl shadow-lg p-6 border border-gray-200 sticky bottom-4">
        <a
          href="/admin/subcategories"
          class="btn-secondary flex items-center"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Cancel
        </a>
        <button
          type="submit"
          class="btn-primary flex items-center"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          <%= subcategory ? 'Update' : 'Create' %> Sub-Category
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  // Initialize CKEditor for rich text fields
  ClassicEditor.create(document.querySelector("#shortDescription"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', '|', 'undo', 'redo']
  }).catch((error) => {
    console.error(error);
  });
  
  ClassicEditor.create(document.querySelector("#fullDescription"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
  }).catch((error) => {
    console.error(error);
  });

  ClassicEditor.create(document.querySelector("#metaDescription"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
  }).catch((error) => {
    console.error(error);
  });

  ClassicEditor.create(document.querySelector("#ogDescription"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
  }).catch((error) => {
    console.error(error);
  });

  ClassicEditor.create(document.querySelector("#schemaType"), {
    toolbar: ['heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|', 'undo', 'redo']
  }).catch((error) => {
    console.error(error);
  });
  
  // Auto-generate slug from name
  document.querySelector('input[name="name"]').addEventListener('input', function(e) {
    const slugField = document.querySelector('input[name="slug"]');
    if (!slugField.value || slugField.dataset.auto !== 'false') {
      const slug = e.target.value
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');
      slugField.value = slug;
      slugField.dataset.auto = 'true';
    }

    const canonicalUrlField = document.querySelector('input[name="canonicalUrl"]');
    const s = e.target.value
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');
    canonicalUrlField.value = 'https://www.rashivani.com/' + s;
    canonicalUrlField.dataset.auto = 'true';
  });
  
  document.querySelector('input[name="slug"]').addEventListener('input', function() {
    this.dataset.auto = 'false';
  });
  document.querySelector('input[name="canonicalUrl"]').addEventListener('input', function() {
    this.dataset.auto = 'false';
  });
</script>
