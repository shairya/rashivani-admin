<!-- File: views/subcategories/form.ejs -->
<h2><%= subcategory ? 'Edit' : 'Create' %> Sub-Category</h2>
<form method="POST" action="/admin/subcategories/save">
  <% if (subcategory) { %>
    <input type="hidden" name="id" value="<%= subcategory.id %>">
  <% } %>
  <label>Name:</label>
  <input type="text" name="name" value="<%= subcategory ? subcategory.name : '' %>" required>

  <label>Category:</label>
  <select name="categoryId" required>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.id %>" <%= subcategory && subcategory.categoryId === cat.id ? 'selected' : '' %>>
        <%= cat.name %>
      </option>
    <% }) %>
  </select>

  <button type="submit">Save</button>
</form>