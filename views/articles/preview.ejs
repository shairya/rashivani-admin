<!-- File: views/articles/preview.ejs -->
<div class="preview-page-wrapper">
  <!-- Page Header -->
  <div class="preview-page-header">
    <div>
      <h1 class="preview-page-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
        Article Preview | लेख पूर्वावलोकन
      </h1>
      <p class="preview-page-subtitle">Preview how your article will appear | आपका लेख कैसा दिखेगा इसका पूर्वावलोकन करें</p>
    </div>
    <div class="preview-header-actions">
      <a href="/admin/articles/edit/<%= article.id %>" class="action-btn action-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"></path>
          <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
        </svg>
        Edit Article | लेख संपादित करें
      </a>
      <a href="/admin/articles" class="action-btn action-btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to List | सूची में वापस जाएं
      </a>
    </div>
  </div>

  <!-- Status Banner -->
  <div class="preview-status-banner status-<%= article.status.toLowerCase() %>">
    <div class="status-badge-large">
      <% if (article.status === 'Active') { %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span>Active - Published | सक्रिय - प्रकाशित</span>
      <% } else if (article.status === 'Draft') { %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"></path>
          <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
        </svg>
        <span>Draft - Not Published | मसौदा - अप्रकाशित</span>
      <% } else { %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="15" y1="9" x2="9" y2="15"></line>
          <line x1="9" y1="9" x2="15" y2="15"></line>
        </svg>
        <span>Inactive | निष्क्रिय</span>
      <% } %>
    </div>
  </div>

  <!-- Article Preview Content -->
  <div class="preview-content-container">
    <!-- Main Article Content -->
    <div class="preview-article-content">
      <article class="article-preview">
        <!-- Article Header -->
        <header class="article-header">
          <% if (article.imageUrl) { %>
          <div class="article-image">
            <img src="<%= article.imageUrl %>" alt="<%= article.name %>" />
          </div>
          <% } %>
          
          <h1 class="article-title"><%= article.name %></h1>
          
          <% if (article.sanskritTitle) { %>
          <div class="article-sanskrit-title">
            <%= article.sanskritTitle %>
          </div>
          <% } %>

          <div class="article-meta">
            <% if (article.author) { %>
            <span class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              <%= article.author %>
            </span>
            <% } %>
            <span class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <%= new Date(article.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
            </span>
            <% if (article.viewCount) { %>
            <span class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              <%= article.viewCount %> views
            </span>
            <% } %>
          </div>

          <% if (article.tags) { %>
          <div class="article-tags">
            <% article.tags.split(',').forEach(tag => { %>
              <span class="tag"><%= tag.trim() %></span>
            <% }) %>
          </div>
          <% } %>
        </header>

        <!-- Introduction -->
        <% if (article.introText) { %>
        <div class="article-intro">
          <%= article.introText %>
        </div>
        <% } %>

        <!-- Main Content -->
        <% if (article.content) { %>
        <div class="article-content">
          <%- article.content %>
        </div>
        <% } %>

        <!-- Sanskrit & Deity Info -->
        <% if (article.deity || article.verseCount || article.language) { %>
        <div class="article-info-section">
          <h2>Article Information | लेख जानकारी</h2>
          <div class="info-grid">
            <% if (article.deity) { %>
            <div class="info-item">
              <span class="info-label">Deity | देवता:</span>
              <span class="info-value"><%= article.deity %></span>
            </div>
            <% } %>
            <% if (article.verseCount) { %>
            <div class="info-item">
              <span class="info-label">Verse Count | पद्य संख्या:</span>
              <span class="info-value"><%= article.verseCount %></span>
            </div>
            <% } %>
            <% if (article.language) { %>
            <div class="info-item">
              <span class="info-label">Language | भाषा:</span>
              <span class="info-value"><%= article.language %></span>
            </div>
            <% } %>
            <% if (article.bestTime) { %>
            <div class="info-item">
              <span class="info-label">Best Time | सर्वोत्तम समय:</span>
              <span class="info-value"><%= article.bestTime %></span>
            </div>
            <% } %>
            <% if (article.duration) { %>
            <div class="info-item">
              <span class="info-label">Duration | अवधि:</span>
              <span class="info-value"><%= article.duration %></span>
            </div>
            <% } %>
            <% if (article.repetitions) { %>
            <div class="info-item">
              <span class="info-label">Repetitions | पुनरावृत्ति:</span>
              <span class="info-value"><%= article.repetitions %></span>
            </div>
            <% } %>
          </div>
        </div>
        <% } %>

        <!-- Benefits -->
        <% if (article.benefits) { %>
        <div class="article-benefits-section">
          <h2>Benefits | लाभ</h2>
          <div class="benefits-content">
            <%- article.benefits %>
          </div>
        </div>
        <% } %>

        <!-- Full Content -->
        <% if (article.fullContent) { %>
        <div class="article-full-content">
          <h2>Complete Content | पूर्ण सामग्री</h2>
          <div class="full-content-text">
            <%- article.fullContent %>
          </div>
        </div>
        <% } %>

        <!-- Media Section -->
        <% if (article.audioUrl || article.youtubeUrl) { %>
        <div class="article-media-section">
          <h2>Media | मीडिया</h2>
          <% if (article.youtubeUrl) { %>
          <div class="media-item">
            <h3>Video | वीडियो</h3>
            <div class="video-container">
              <iframe width="100%" height="400" src="<%= article.youtubeUrl %>" frameborder="0" allowfullscreen></iframe>
            </div>
          </div>
          <% } %>
          <% if (article.audioUrl) { %>
          <div class="media-item">
            <h3>Audio | ऑडियो</h3>
            <audio controls style="width: 100%;">
              <source src="<%= article.audioUrl %>" type="audio/mpeg">
              Your browser does not support the audio element.
            </audio>
          </div>
          <% } %>
        </div>
        <% } %>

        <!-- Related Info -->
        <% if (article.relatedMantras || article.festivals) { %>
        <div class="article-related-section">
          <% if (article.relatedMantras) { %>
          <div class="related-item">
            <h3>Related Mantras | संबंधित मंत्र</h3>
            <p><%= article.relatedMantras %></p>
          </div>
          <% } %>
          <% if (article.festivals) { %>
          <div class="related-item">
            <h3>Associated Festivals | संबंधित त्यौहार</h3>
            <p><%= article.festivals %></p>
          </div>
          <% } %>
        </div>
        <% } %>
      </article>
    </div>

    <!-- Sidebar -->
    <aside class="preview-sidebar">
      <!-- Article Details Card -->
      <div class="sidebar-card">
        <h3 class="sidebar-card-title">Article Details | लेख विवरण</h3>
        <div class="sidebar-card-content">
          <div class="detail-row">
            <span class="detail-label">Category | श्रेणी:</span>
            <span class="detail-value"><%= article.Category?.name || 'N/A' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Sub-Category | उप-श्रेणी:</span>
            <span class="detail-value"><%= article.SubCategory?.name || 'N/A' %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Status | स्थिति:</span>
            <span class="detail-value">
              <% if (article.status === 'Active') { %>
                <span class="status-badge status-active">
                  <span class="status-dot"></span>
                  Active
                </span>
              <% } else if (article.status === 'InActive') { %>
                <span class="status-badge status-inactive">
                  <span class="status-dot"></span>
                  InActive
                </span>
              <% } else { %>
                <span class="status-badge status-draft">
                  <span class="status-dot"></span>
                  Draft
                </span>
              <% } %>
            </span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Slug | स्लग:</span>
            <span class="detail-value slug-value"><%= article.slug %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Created | बनाया गया:</span>
            <span class="detail-value"><%= new Date(article.createdAt).toLocaleDateString() %></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Last Updated | अंतिम अपडेट:</span>
            <span class="detail-value"><%= new Date(article.updatedAt).toLocaleDateString() %></span>
          </div>
        </div>
      </div>

      <!-- SEO Information Card -->
      <% if (article.metaTitle || article.metaDescription || article.keywords) { %>
      <div class="sidebar-card">
        <h3 class="sidebar-card-title">SEO Information | एसईओ जानकारी</h3>
        <div class="sidebar-card-content">
          <% if (article.metaTitle) { %>
          <div class="detail-row">
            <span class="detail-label">Meta Title | मेटा शीर्षक:</span>
            <span class="detail-value"><%= article.metaTitle %></span>
          </div>
          <% } %>
          <% if (article.metaDescription) { %>
          <div class="detail-row">
            <span class="detail-label">Meta Description | मेटा विवरण:</span>
            <span class="detail-value"><%= article.metaDescription %></span>
          </div>
          <% } %>
          <% if (article.keywords) { %>
          <div class="detail-row">
            <span class="detail-label">Keywords | मुख्य शब्द:</span>
            <span class="detail-value"><%= article.keywords %></span>
          </div>
          <% } %>
          <% if (article.canonicalUrl) { %>
          <div class="detail-row">
            <span class="detail-label">Canonical URL | कैनोनिकल यूआरएल:</span>
            <span class="detail-value slug-value"><%= article.canonicalUrl %></span>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- Quick Actions Card -->
      <div class="sidebar-card">
        <h3 class="sidebar-card-title">Quick Actions | त्वरित क्रियाएं</h3>
        <div class="sidebar-card-actions">
          <a href="/admin/articles/edit/<%= article.id %>" class="sidebar-action-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9"></path>
              <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
            </svg>
            Edit Article | संपादित करें
          </a>
          <form method="POST" action="/admin/articles/toggle-status/<%= article.id %>" class="sidebar-action-form">
            <button type="submit" class="sidebar-action-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M12 1v6m0 6v6"></path>
              </svg>
              Toggle Status | स्थिति बदलें
            </button>
          </form>
          <a href="/admin/articles" class="sidebar-action-btn sidebar-action-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            </svg>
            Back to Articles | लेखों पर वापस जाएं
          </a>
        </div>
      </div>
    </aside>
  </div>
</div>

<style>
  .preview-page-wrapper {
    padding: 0;
  }

  .preview-page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 2px solid #f0f0f0;
  }

  .preview-page-title {
    display: flex;
    align-items: center;
    gap: 15px;
    font-size: 2rem;
    font-weight: 700;
    color: #1a202c;
    margin: 0;
  }

  .preview-page-title svg {
    color: #8b5cf6;
  }

  .preview-page-subtitle {
    color: #718096;
    margin-top: 8px;
    font-size: 1rem;
  }

  .preview-header-actions {
    display: flex;
    gap: 12px;
  }

  .preview-status-banner {
    padding: 16px 24px;
    border-radius: 12px;
    margin-bottom: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-status-banner.status-active {
    background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
    border: 1px solid #b1dfbb;
  }

  .preview-status-banner.status-draft {
    background: linear-gradient(135deg, #fff3cd 0%, #ffe69c 100%);
    border: 1px solid #ffc107;
  }

  .preview-status-banner.status-inactive {
    background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
    border: 1px solid #f1b0b7;
  }

  .status-badge-large {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .preview-content-container {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 30px;
  }

  .preview-article-content {
    min-width: 0;
  }

  .article-preview {
    background: white;
    border-radius: 16px;
    padding: 40px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .article-header {
    margin-bottom: 40px;
  }

  .article-image {
    margin-bottom: 30px;
    border-radius: 12px;
    overflow: hidden;
  }

  .article-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .article-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #1a202c;
    line-height: 1.2;
    margin: 0 0 15px 0;
  }

  .article-sanskrit-title {
    font-size: 1.5rem;
    font-weight: 500;
    color: #8b5cf6;
    margin-bottom: 20px;
    font-style: italic;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin: 20px 0;
    padding: 15px 0;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #718096;
    font-size: 0.95rem;
  }

  .meta-item svg {
    color: #8b5cf6;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .article-tags .tag {
    background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
    color: white;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .article-intro {
    background: #f7fafc;
    border-left: 4px solid #8b5cf6;
    padding: 20px 24px;
    margin: 30px 0;
    border-radius: 8px;
    font-size: 1.1rem;
    line-height: 1.7;
    color: #2d3748;
  }

  .article-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #2d3748;
    margin: 30px 0;
  }

  .article-content h2 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1a202c;
    margin: 30px 0 15px;
  }

  .article-content h3 {
    font-size: 1.4rem;
    font-weight: 600;
    color: #2d3748;
    margin: 25px 0 12px;
  }

  .article-content p {
    margin: 15px 0;
  }

  .article-info-section,
  .article-benefits-section,
  .article-full-content,
  .article-media-section,
  .article-related-section {
    margin: 40px 0;
    padding: 30px;
    background: #f7fafc;
    border-radius: 12px;
  }

  .article-info-section h2,
  .article-benefits-section h2,
  .article-full-content h2,
  .article-media-section h2 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 20px 0;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .info-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #718096;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-value {
    font-size: 1rem;
    font-weight: 500;
    color: #2d3748;
  }

  .benefits-content,
  .full-content-text {
    line-height: 1.8;
    color: #2d3748;
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .media-item {
    margin: 20px 0;
  }

  .media-item h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #2d3748;
    margin-bottom: 12px;
  }

  .article-related-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
  }

  .related-item h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: #1a202c;
    margin-bottom: 10px;
  }

  .related-item p {
    color: #4a5568;
    line-height: 1.6;
  }

  .preview-sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-card {
    background: white;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .sidebar-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #1a202c;
    margin: 0 0 15px 0;
    padding-bottom: 12px;
    border-bottom: 2px solid #f0f0f0;
  }

  .sidebar-card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .detail-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .detail-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #718096;
  }

  .detail-value {
    font-size: 0.95rem;
    color: #2d3748;
    word-break: break-word;
  }

  .slug-value {
    font-family: 'Courier New', monospace;
    font-size: 0.875rem;
    background: #f7fafc;
    padding: 4px 8px;
    border-radius: 4px;
  }

  .sidebar-card-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sidebar-action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px 16px;
    background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
