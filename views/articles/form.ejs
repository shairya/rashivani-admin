<!-- File: views/articles/form.ejs -->
<div class="form-page-wrapper">
  <!-- Page Header -->
  <div class="form-page-header">
    <div>
      <h1 class="form-page-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
        </svg>
        <%= title %>
      </h1>
      <p class="form-page-subtitle">Fill in the details below to <%= article ? 'update' : 'create' %> your article</p>
    </div>
    <a href="/admin/articles" class="action-btn action-btn-secondary">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Back to List
    </a>
  </div>

  <!-- AI Content Generator Section -->
  <% if (!article) { %>
  <div class="ai-generator-card">
    <div class="ai-generator-header">
      <div class="ai-generator-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      </div>
      <div>
        <h2>🤖 AI Content Writer</h2>
        <p>Generate unique, SEO-optimized content automatically</p>
      </div>
    </div>
    
    <div class="ai-generator-body">
      <div class="form-group-modern">
        <label>Enter Your Topic or Brief Description</label>
        <textarea
          id="aiTopicInput"
          rows="3"
          class="form-input-modern"
          placeholder="Example: Write about Hanuman Chalisa benefits and meaning for devotees..."
        ></textarea>
      </div>
      
      <div class="form-grid-3">
        <div class="form-group-modern">
          <label>Select Category</label>
          <select id="aiCategorySelect" class="form-input-modern">
            <option value="">Select Category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group-modern">
          <label>Select Sub-Category</label>
          <select id="aiSubCategorySelect" class="form-input-modern">
            <option value="">Select Sub-Category</option>
            <% subcategories.forEach(sub => { %>
              <option value="<%= sub.id %>"><%= sub.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="form-group-modern">
          <label>Content Style</label>
          <select id="aiContentStyle" class="form-input-modern">
            <option value="devotional">Devotional & Spiritual</option>
            <option value="informative">Informative & Educational</option>
            <option value="beginner">Beginner-Friendly Guide</option>
            <option value="detailed">Detailed & Comprehensive</option>
          </select>
        </div>
      </div>

      <div class="ai-generator-actions">
        <button type="button" id="generateAIContent" class="ai-generate-btn">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
          </svg>
          Generate Content with AI
        </button>
        <div id="aiLoadingIndicator" class="ai-loading hidden">
          <div class="spinner"></div>
          <span>Generating amazing content...</span>
        </div>
      </div>
      
      <div id="aiSuccessMessage" class="alert-success hidden">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <span>Content generated successfully! All fields have been filled. Review and submit below.</span>
      </div>
      
      <div id="aiErrorMessage" class="alert-error hidden">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span id="aiErrorText"></span>
      </div>
    </div>
  </div>
  <% } %>

  <form method="POST" action="/admin/articles/save" enctype="multipart/form-data" id="articleForm" class="article-form">
    <% if (article) { %>
    <input type="hidden" name="id" value="<%= article.id %>" />
    <% } %>

    <!-- Basic Information -->
    <div class="form-section-card">
      <div class="form-section-header header-blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <h2>Basic Information</h2>
      </div>
      <div class="form-section-body">
        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>Article Name <span class="required">*</span></label>
            <input type="text" name="name" value="<%= article?.name || '' %>" required class="form-input-modern" placeholder="Enter article name" />
          </div>
          <div class="form-group-modern">
            <label>Slug <span class="required">*</span></label>
            <input type="text" name="slug" value="<%= article?.slug || '' %>" required class="form-input-modern" placeholder="auto-generated-slug" />
          </div>
        </div>

        <div class="form-grid-3">
          <div class="form-group-modern">
            <label>Category <span class="required">*</span></label>
            <select name="categoryId" required class="form-input-modern">
              <option value="">Select Category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat.id %>" <%= article?.categoryId === cat.id ? 'selected' : '' %>><%= cat.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group-modern">
            <label>Sub-Category <span class="required">*</span></label>
            <select name="subCategoryId" required class="form-input-modern">
              <option value="">Select Sub-Category</option>
              <% subcategories.forEach(sub => { %>
                <option value="<%= sub.id %>" <%= article?.subCategoryId === sub.id ? 'selected' : '' %>><%= sub.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group-modern">
            <label>Status</label>
            <select name="status" class="form-input-modern">
              <option value="Draft" <%= article?.status === 'Draft' ? 'selected' : '' %>>📝 Draft</option>
              <option value="Active" <%= article?.status === 'Active' ? 'selected' : '' %>>✅ Active</option>
              <option value="InActive" <%= article?.status === 'InActive' ? 'selected' : '' %>>⭕ Inactive</option>
            </select>
          </div>
        </div>

        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>Author Name</label>
            <input type="text" name="author" value="<%= article?.author || '' %>" class="form-input-modern" placeholder="Enter author name" />
          </div>
          <div class="form-group-modern">
            <label>Tags (comma-separated)</label>
            <input type="text" name="tags" value="<%= article?.tags || '' %>" class="form-input-modern" placeholder="tag1, tag2, tag3" />
          </div>
        </div>
      </div>
    </div>

    <!-- Sanskrit & Deity Information -->
    <div class="form-section-card">
      <div class="form-section-header header-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
        </svg>
        <h2>Sanskrit & Deity Information</h2>
      </div>
      <div class="form-section-body">
        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>Sanskrit Title</label>
            <input type="text" name="sanskritTitle" value="<%= article?.sanskritTitle || '' %>" class="form-input-modern" placeholder="Enter Sanskrit title" />
          </div>
          <div class="form-group-modern">
            <label>Deity</label>
            <input type="text" name="deity" value="<%= article?.deity || '' %>" class="form-input-modern" placeholder="Enter deity name" />
          </div>
        </div>

        <div class="form-grid-3">
          <div class="form-group-modern">
            <label>Verse Count</label>
            <input type="number" name="verseCount" value="<%= article?.verseCount || '' %>" class="form-input-modern" placeholder="0" />
          </div>
          <div class="form-group-modern">
            <label>Language</label>
            <input type="text" name="language" value="<%= article?.language || '' %>" class="form-input-modern" placeholder="Sanskrit, Hindi, etc." />
          </div>
          <div class="form-group-modern">
            <label>Keywords</label>
            <input type="text" name="keywords" value="<%= article?.keywords || '' %>" class="form-input-modern" placeholder="keyword1, keyword2" />
          </div>
        </div>
      </div>
    </div>

    <!-- Content Section -->
    <div class="form-section-card">
      <div class="form-section-header header-purple">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
        </svg>
        <h2>Content</h2>
      </div>
      <div class="form-section-body">
        <div class="form-group-modern">
          <label>Main Content</label>
          <textarea name="content" id="editor" rows="8" class="form-input-modern" placeholder="Enter main content..."><%= article?.content || '' %></textarea>
        </div>
        <div class="form-group-modern">
          <label>Intro Text</label>
          <textarea name="introText" id="introText" rows="4" class="form-input-modern" placeholder="Enter introduction text..."><%= article?.introText || '' %></textarea>
        </div>
        <div class="form-group-modern">
          <label>Full Content</label>
          <textarea name="fullContent" id="fullContent" rows="8" class="form-input-modern" placeholder="Enter full detailed content..."><%= article?.fullContent || '' %></textarea>
        </div>
        <div class="form-group-modern">
          <label>Verses</label>
          <textarea name="verses" id="verses-editor" rows="6" class="form-input-modern" placeholder="Enter verses..."><%= article?.verses || '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Benefits & Details -->
    <div class="form-section-card">
      <div class="form-section-header header-green">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <h2>Benefits & Details</h2>
      </div>
      <div class="form-section-body">
        <div class="form-group-modern">
          <label>Benefits (one per line)</label>
          <textarea name="benefits" rows="4" class="form-input-modern" placeholder="Enter benefits, one per line"><%= article?.benefits || '' %></textarea>
        </div>
        <div class="form-grid-3">
          <div class="form-group-modern">
            <label>Best Time</label>
            <input type="text" name="bestTime" value="<%= article?.bestTime || '' %>" class="form-input-modern" placeholder="e.g., Morning, Evening" />
          </div>
          <div class="form-group-modern">
            <label>Duration</label>
            <input type="text" name="duration" value="<%= article?.duration || '' %>" class="form-input-modern" placeholder="e.g., 15 minutes" />
          </div>
          <div class="form-group-modern">
            <label>Repetitions</label>
            <input type="text" name="repetitions" value="<%= article?.repetitions || '' %>" class="form-input-modern" placeholder="e.g., 108 times" />
          </div>
        </div>
      </div>
    </div>

    <!-- Media Section -->
    <div class="form-section-card">
      <div class="form-section-header header-pink">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <polyline points="21 15 16 10 5 21"></polyline>
        </svg>
        <h2>Media</h2>
      </div>
      <div class="form-section-body">
        <div class="form-grid-3">
          <div class="form-group-modern">
            <label>Article Image</label>
            <input type="file" name="imageUrl" accept="image/*" class="form-input-modern file-input" />
          </div>
          <div class="form-group-modern">
            <label>Audio URL</label>
            <input type="text" name="audioUrl" value="<%= article?.audioUrl || '' %>" class="form-input-modern" placeholder="https://example.com/audio.mp3" />
          </div>
          <div class="form-group-modern">
            <label>YouTube URL</label>
            <input type="text" name="youtubeUrl" value="<%= article?.youtubeUrl || '' %>" class="form-input-modern" placeholder="https://youtube.com/watch?v=..." />
          </div>
        </div>
      </div>
    </div>

    <!-- Related Content -->
    <div class="form-section-card">
      <div class="form-section-header header-cyan">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
        </svg>
        <h2>Related Content</h2>
      </div>
      <div class="form-section-body">
        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>Related Mantras</label>
            <input type="text" name="relatedMantras" value="<%= article?.relatedMantras || '' %>" class="form-input-modern" placeholder="Comma-separated mantra names" />
          </div>
          <div class="form-group-modern">
            <label>Festivals</label>
            <input type="text" name="festivals" value="<%= article?.festivals || '' %>" class="form-input-modern" placeholder="Comma-separated festival names" />
          </div>
        </div>
      </div>
    </div>

    <!-- SEO Meta Tags -->
    <div class="form-section-card">
      <div class="form-section-header header-teal">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <h2>SEO Meta Tags</h2>
      </div>
      <div class="form-section-body">
        <div class="form-group-modern">
          <label>Meta Title</label>
          <input type="text" name="metaTitle" value="<%= article?.metaTitle || '' %>" maxlength="60" class="form-input-modern" placeholder="Recommended: 50-60 characters" />
          <span class="field-hint">Optimal length: 50-60 characters</span>
        </div>
        <div class="form-group-modern">
          <label>Meta Description</label>
          <textarea name="metaDescription" id="metaDescription" rows="3" maxlength="160" class="form-input-modern" placeholder="Recommended: 150-160 characters"><%= article?.metaDescription || '' %></textarea>
          <span class="field-hint">Optimal length: 150-160 characters</span>
        </div>
      </div>
    </div>

    <!-- Open Graph Tags -->
    <div class="form-section-card">
      <div class="form-section-header header-rose">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
          <polyline points="15 3 21 3 21 9"></polyline>
          <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
        <h2>Open Graph (Social Media)</h2>
      </div>
      <div class="form-section-body">
        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>OG Title</label>
            <input type="text" name="ogTitle" value="<%= article?.ogTitle || '' %>" class="form-input-modern" placeholder="Title for social media sharing" />
          </div>
          <div class="form-group-modern">
            <label>OG Image</label>
            <input type="file" name="ogImage" accept="image/*" class="form-input-modern file-input" />
          </div>
        </div>
        <div class="form-group-modern">
          <label>OG Description</label>
          <textarea name="ogDescription" id="ogDescription" rows="3" class="form-input-modern" placeholder="Description for social media sharing"><%= article?.ogDescription || '' %></textarea>
        </div>
      </div>
    </div>

    <!-- Advanced SEO & Publishing -->
    <div class="form-section-card">
      <div class="form-section-header header-indigo">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
        </svg>
        <h2>Advanced SEO & Publishing</h2>
      </div>
      <div class="form-section-body">
        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>Canonical URL</label>
            <input type="text" name="canonicalUrl" value="<%= article?.canonicalUrl || '' %>" class="form-input-modern" placeholder="https://example.com/article-name" />
            <span class="field-hint">Specify the preferred URL for this article</span>
          </div>
          <div class="form-group-modern">
            <label>Schema Type</label>
            <input type="text" name="schemaType" value="<%= article?.schemaType || '' %>" class="form-input-modern" placeholder="e.g., Article, BlogPosting" />
            <span class="field-hint">Schema.org markup type for structured data</span>
          </div>
        </div>
        <div class="form-grid-2">
          <div class="form-group-modern">
            <label>Publish Date</label>
            <input type="datetime-local" name="publishDate" value="<%= (article?.publishDate instanceof Date && !isNaN(article.publishDate)) ? article.publishDate.toISOString().slice(0,16) : '' %>" class="form-input-modern" />
          </div>
          <div class="form-group-modern">
            <label>Schedule Publish Date</label>
            <input type="datetime-local" name="scheduledPublishDate" value="<%= (article?.scheduledPublishDate instanceof Date && !isNaN(article.scheduledPublishDate)) ? article.scheduledPublishDate.toISOString().slice(0,16) : '' %>" class="form-input-modern" />
          </div>
        </div>
      </div>
    </div>

    <!-- Submit Actions -->
    <div class="form-actions-sticky">
      <a href="/admin/articles" class="action-btn action-btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Cancel
      </a>
      <button type="submit" class="action-btn action-btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        <%= article ? 'Update' : 'Create' %> Article
      </button>
    </div>
  </form>
</div>

<script>
  // Initialize CKEditor
  window.editorInstances = {};
  ClassicEditor.create(document.querySelector('#editor')).then(editor => { window.editorInstances.editor = editor; }).catch(error => console.error(error));
  ClassicEditor.create(document.querySelector('#fullContent')).then(editor => { window.editorInstances.fullContent = editor; }).catch(error => console.error(error));
  ClassicEditor.create(document.querySelector('#introText')).then(editor => { window.editorInstances.introText = editor; }).catch(error => console.error(error));
  ClassicEditor.create(document.querySelector('#verses-editor')).then(editor => { window.editorInstances.verses = editor; }).catch(error => console.error(error));
  ClassicEditor.create(document.querySelector('#ogDescription')).then(editor => { window.editorInstances.ogDescription = editor; }).catch(error => console.error(error));
  ClassicEditor.create(document.querySelector('#metaDescription')).then(editor => { window.editorInstances.metaDescription = editor; }).catch(error => console.error(error));

  // Auto-generate slug
  document.querySelector('input[name="name"]').addEventListener('input', function(e) {
    const slugField = document.querySelector('input[name="slug"]');
    if (!slugField.value || slugField.dataset.auto !== 'false') {
      const slug = e.target.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      slugField.value = slug;
      slugField.dataset.auto = 'true';
    }
  });
  
  document.querySelector('input[name="slug"]').addEventListener('input', function() {
    this.dataset.auto = 'false';
  });

  // AI Content Generation
  const generateButton = document.getElementById('generateAIContent');
  if (generateButton) {
    generateButton.addEventListener('click', async function() {
      const topic = document.getElementById('aiTopicInput').value.trim();
      const categoryId = document.getElementById('aiCategorySelect').value;
      const subCategoryId = document.getElementById('aiSubCategorySelect').value;
      const contentStyle = document.getElementById('aiContentStyle').value;
      
      if (!topic) {
        showError('Please enter a topic or description');
        return;
      }
      if (!categoryId || !subCategoryId) {
        showError('Please select both category and sub-category');
        return;
      }

      generateButton.disabled = true;
      document.getElementById('aiLoadingIndicator').classList.remove('hidden');
      document.getElementById('aiSuccessMessage').classList.add('hidden');
      document.getElementById('aiErrorMessage').classList.add('hidden');

      try {
        const response = await fetch('/admin/articles/generate-ai-content', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ topic, categoryId, subCategoryId, contentStyle })
        });

        const data = await response.json();

        if (response.ok) {
          populateFormFields(data.content);
          document.getElementById('aiSuccessMessage').classList.remove('hidden');
          setTimeout(() => {
            document.getElementById('articleForm').scrollIntoView({ behavior: 'smooth' });
          }, 1000);
        } else {
          showError(data.error || 'Failed to generate content. Please try again.');
        }
      } catch (error) {
        console.error('Error:', error);
        showError('An error occurred while generating content. Please try again.');
      } finally {
        generateButton.disabled = false;
        document.getElementById('aiLoadingIndicator').classList.add('hidden');
      }
    });
  }

  function populateFormFields(content) {
    document.querySelector('input[name="name"]').value = content.name || '';
    document.querySelector('input[name="slug"]').value = content.slug || '';
    document.querySelector('select[name="categoryId"]').value = content.categoryId || '';
    document.querySelector('select[name="subCategoryId"]').value = content.subCategoryId || '';
    document.querySelector('select[name="status"]').value = content.status || 'Draft';
    document.querySelector('input[name="author"]').value = content.author || '';
    document.querySelector('input[name="tags"]').value = content.tags || '';
    document.querySelector('input[name="sanskritTitle"]').value = content.sanskritTitle || '';
    document.querySelector('input[name="deity"]').value = content.deity || '';
    document.querySelector('input[name="verseCount"]').value = content.verseCount || '';
    document.querySelector('input[name="language"]').value = content.language || '';
    document.querySelector('input[name="keywords"]').value = content.keywords || '';

    if (window.editorInstances.editor) window.editorInstances.editor.setData(content.content || '');
    if (window.editorInstances.introText) window.editorInstances.introText.setData(content.introText || '');
    if (window.editorInstances.fullContent) window.editorInstances.fullContent.setData(content.fullContent || '');
    if (window.editorInstances.verses) window.editorInstances.verses.setData(content.verses || '');

    document.querySelector('textarea[name="benefits"]').value = content.benefits || '';
    document.querySelector('input[name="bestTime"]').value = content.bestTime || '';
    document.querySelector('input[name="duration"]').value = content.duration || '';
    document.querySelector('input[name="repetitions"]').value = content.repetitions || '';
    document.querySelector('input[name="audioUrl"]').value = content.audioUrl || '';
    document.querySelector('input[name="youtubeUrl"]').value = content.youtubeUrl || '';
    document.querySelector('input[name="relatedMantras"]').value = content.relatedMantras || '';
    document.querySelector('input[name="festivals"]').value = content.festivals || '';
    document.querySelector('input[name="metaTitle"]').value = content.metaTitle || '';
    
    if (window.editorInstances.metaDescription) window.editorInstances.metaDescription.setData(content.metaDescription || '');

    document.querySelector('input[name="ogTitle"]').value = content.ogTitle || '';
    if (window.editorInstances.ogDescription) window.editorInstances.ogDescription.setData(content.ogDescription || '');
    document.querySelector('input[name="canonicalUrl"]').value = content.canonicalUrl || '';
  }

  function showError(message) {
    document.getElementById('aiErrorText').textContent = message;
    document.getElementById('aiErrorMessage').classList.remove('hidden');
    setTimeout(() => {
      document.getElementById('aiErrorMessage').classList.add('hidden');
    }, 5000);
  }
</script>
