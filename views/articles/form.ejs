<script>
  ClassicEditor
    .create(document.querySelector('#editor'))
    .catch(error => {
      console.error(error);
    });
    ClassicEditor
    .create(document.querySelector('#fullContent'))
    .catch(error => {
      console.error(error);
    });
    ClassicEditor
    .create(document.querySelector('#introText'))
    .catch(error => {
      console.error(error);
    });
    ClassicEditor
    .create(document.querySelector('#verses-editor'))
    .catch(error => {
      console.error(error);
    });

    ClassicEditor
    .create(document.querySelector('#ogDescription'))
    .catch(error => {
      console.error(error);
    });
    ClassicEditor
    .create(document.querySelector('#metaDescription'))
    .catch(error => {
      console.error(error);
    });
</script>
