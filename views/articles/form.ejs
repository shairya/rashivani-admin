<!-- File: views/articles/form.ejs -->
<h2><%= title %></h2>
<form method="POST" action="/admin/articles/save" enctype="multipart/form-data">
  <% if (article) { %>
    <input type="hidden" name="id" value="<%= article.id %>">
    <div class="mb-3">
      <label class="form-label">Select Language:</label>
      <select name="languageCode">
        <option value="en" <%= article?.languageCode === 'en' ? 'selected' : '' %>>English</option>
        <option value="hi" <%= article?.languageCode === 'hi' ? 'selected' : '' %>>Hindi</option>
      </select>
    </div>
  <% } %>
  <div class="mb-3">
    <label class="form-label">Article Name</label>
    <input type="text" name="name" class="form-control"  value="<%= article?.name || '' %>" required>
  </div>
  
  <div class="mb-3">
    <label class="form-label">Slug:</label>
    <input type="text" class="form-control" name="slug" value="<%= article?.slug || '' %>" required>
  </div>

  <div class="mb-3">
    <label class="form-label">Category:</label>
    <select name="categoryId" class="form-control" required>
      <% categories.forEach(cat => { %>
        <option value="<%= cat.id %>" <%= article?.categoryId === cat.id ? 'selected' : '' %>><%= cat.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label">Sub-Category:</label>
    <select name="subCategoryId" class="form-control" required>
      <% subcategories.forEach(sub => { %>
        <option value="<%= sub.id %>" <%= article?.subCategoryId === sub.id ? 'selected' : '' %>><%= sub.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label">Keywords</label>
    <input type="text" name="keywords" class="form-control" value="<%= article?.keywords || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Sanskrit Title</label>
    <input type="text" name="sanskritTitle" class="form-control" value="<%= article?.sanskritTitle || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Deity</label>
    <input type="text" name="deity" class="form-control" value="<%= article?.deity || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Verse Count</label>
    <input type="number" name="verseCount" class="form-control" value="<%= article?.verseCount || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Language</label>
    <input type="text" name="language" class="form-control" value="<%= article?.language || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Benefits (one per line)</label>
    <textarea name="benefits" class="form-control" rows="4"><%= article?.benefits || '' %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Content:</label>
    <textarea name="content" class="form-control" id="editor" rows="10"><%= article?.content || '' %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Tags (comma-separated):</label>
    <input type="text" class="form-control" name="tags" value="<%= article?.tags || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Author Name:</label>
    <input type="text" class="form-control" name="author" value="<%= article?.author || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Best Time:</label>
    <input type="text" class="form-control" name="bestTime" value="<%= article?.bestTime || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Duration:</label>
    <input type="text" class="form-control" name="duration" value="<%= article?.duration || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Repetitions:</label>
    <input type="text" class="form-control" name="repetitions" value="<%= article?.repetitions || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Verses:</label>
    <textarea name="verses" class="form-control" id="verses-editor"><%= article?.verses || '' %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Intro Text:</label>
    <textarea name="introText" class="form-control" id="introText"><%= article?.introText || '' %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">Full Text:</label>
    <textarea name="fullContent" class="form-control" id="fullContent"><%= article?.fullContent || '' %></textarea>
  </div>
  
  <div class="mb-3">
    <label class="form-label">Audio Url:</label>
    <input type="text" class="form-control" name="audioUrl" value="<%= article?.audioUrl || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Image:</label>
    <input type="file" class="form-control" name="imageUrl" value="<%= article?.imageUrl || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Youtube Url:</label>
    <input type="text" class="form-control" name="youtubeUrl" value="<%= article?.youtubeUrl || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Related Mantras:</label>
    <input type="text" class="form-control" name="relatedMantras" value="<%= article?.relatedMantras || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Festivals:</label>
    <input type="text" class="form-control" name="festivals" value="<%= article?.festivals || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Meta Title:</label>
    <input type="text" class="form-control" name="metaTitle" value="<%= article?.metaTitle || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Meta Description:</label>
    <textarea name="metaDescription" class="form-control" id="metaDescription"><%= article?.metaDescription || '' %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">OG Title:</label>
    <input type="text" class="form-control" name="ogTitle" value="<%= article?.ogTitle || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">OG Description:</label>
    <textarea name="ogDescription" class="form-control" id="ogDescription"><%= article?.ogDescription || '' %></textarea>
  </div>

  <div class="mb-3">
    <label class="form-label">OG Image:</label>
    <input type="file" class="form-control" name="ogImage" value="<%= article?.ogImage || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Canonical URL:</label>
    <input type="text" class="form-control" name="canonicalUrl" value="<%= article?.canonicalUrl || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Schema Type:</label>
    <input
      class="form-control"
      type="text"
      name="schemaType"
      value="<%= article ? article.schemaType : '' %>"
    />
  </div>

  <div class="mb-3">
    <label class="form-label">Publish Date:</label>
    <input type="date" class="form-control" name="publishDate" value="<%= article?.publishDate?.toISOString().split('T')[0] || '' %>">
  </div>

  <div class="mb-3">
    <label class="form-label">Schedule Publish Date:</label>
    <input type="datetime-local" class="form-control" name="scheduledPublishDate" value="<%= article?.scheduledPublishDate?.toISOString().slice(0,16) || '' %>">
  </div>
  
  <div class="mb-3">
    <label class="form-label">Status:</label>
    <select name="status" class="form-control">
      <option value="Draft" <%= article?.status === 'Draft' ? 'selected' : '' %>>Draft</option>
      <option value="Active" <%= article?.status === 'Active' ? 'selected' : '' %>>Active</option>
      <option value="InActive" <%= article?.status === 'InActive' ? 'selected' : '' %>>InActive</option>
    </select>
  </div>

  <button type="submit" class="btn btn-primary">Save</button>
</form>
