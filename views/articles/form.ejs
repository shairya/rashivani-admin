                name="ogImage"
                accept="image/*"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition-all duration-200 outline-none hover:border-pink-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100"
              />
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">OG Description</label>
            <textarea
              name="ogDescription"
              id="ogDescription"
              rows="3"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-pink-500 focus:border-transparent transition-all duration-200 outline-none hover:border-pink-400"
              placeholder="Description for social media sharing"
            ><%= article?.ogDescription || '' %></textarea>
          </div>
        </div>
      </div>

      <!-- Advanced SEO & Publishing Card -->
      <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-200 hover:shadow-xl transition-shadow duration-300">
        <div class="bg-gradient-to-r from-indigo-600 to-indigo-700 px-6 py-4">
          <h2 class="text-xl font-semibold text-white flex items-center">
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Advanced SEO & Publishing
          </h2>
        </div>
        <div class="p-6 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Canonical URL</label>
              <input
                type="text"
                name="canonicalUrl"
                value="<%= article?.canonicalUrl || '' %>"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 outline-none hover:border-indigo-400"
                placeholder="https://example.com/article-name"
              />
              <p class="text-xs text-gray-500 mt-1">Specify the preferred URL for this article</p>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Schema Type</label>
              <input
                type="text"
                name="schemaType"
                id="schemaType"
                value="<%= article ? article.schemaType : '' %>"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 outline-none hover:border-indigo-400"
                placeholder="e.g., Article, BlogPosting"
              />
              <p class="text-xs text-gray-500 mt-1">Schema.org markup type for structured data</p>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Publish Date</label>
              <input
                type="date"
                name="publishDate"
                value="<%= article?.publishDate?.toISOString().split('T')[0] || '' %>"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 outline-none hover:border-indigo-400"
              />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Schedule Publish Date</label>
              <input
                type="datetime-local"
                name="scheduledPublishDate"
                value="<%= article?.scheduledPublishDate?.toISOString().slice(0,16) || '' %>"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all duration-200 outline-none hover:border-indigo-400"
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex items-center justify-between bg-white rounded-2xl shadow-lg p-6 border border-gray-200 sticky bottom-4">
        <a
          href="/admin/articles"
          class="btn-secondary flex items-center"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Cancel
        </a>
        <button
          type="submit"
          class="btn-primary flex items-center"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          <%= article ? 'Update' : 'Create' %> Article
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  // Initialize CKEditor for rich text fields
  ClassicEditor.create(document.querySelector('#editor')).catch(error => {
    console.error(error);
  });
  ClassicEditor.create(document.querySelector('#fullContent')).catch(error => {
    console.error(error);
  });
  ClassicEditor.create(document.querySelector('#introText')).catch(error => {
    console.error(error);
  });
  ClassicEditor.create(document.querySelector('#verses-editor')).catch(error => {
    console.error(error);
  });
  ClassicEditor.create(document.querySelector('#ogDescription')).catch(error => {
    console.error(error);
  });
  ClassicEditor.create(document.querySelector('#metaDescription')).catch(error => {
    console.error(error);
  });

  ClassicEditor.create(document.querySelector('#schemaType')).catch(error => {
    console.error(error);
  });

  // Auto-generate slug from name
  document.querySelector('input[name="name"]').addEventListener('input', function(e) {
    const slugField = document.querySelector('input[name="slug"]');
    if (!slugField.value || slugField.dataset.auto !== 'false') {
      const slug = e.target.value
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)/g, '');
      slugField.value = slug;
      slugField.dataset.auto = 'true';
    }
  });
  
  document.querySelector('input[name="slug"]').addEventListener('input', function() {
    this.dataset.auto = 'false';
  });
</script>
