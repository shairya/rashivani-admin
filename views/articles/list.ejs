<ul>
  <% if (articles && articles.length > 0) { %>
    <% articles.forEach(article => { %>
    <li>
      <strong><%= article.title %></strong> - (<%=
      article.Category?.name %> / <%= article.SubCategory?.name %>) / <%= article.status %> 
      <!-- <a href="/admin/articles/edit/<%= article.id %>">Edit</a> -->
      <form method="POST" action="/admin/articles/toggle-status/<%= article.id %>">
        <button type="submit">
          Toggle to <%= article.status === 'draft' ? 'Published' : 'Draft' %>
        </button>
      </form>
    </li>
    <% }) %>
  <% } %>
</ul>
<div>
  <% if(articles.length > pagination.limit) { %>
    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <a href="?page=<%= i %>&<%= new URLSearchParams(filters).toString() %>">
        <%= i === pagination.page ? `<strong>${i}</strong>` : i %>
      </a>
    <% } %>
  <% } %>
</div>
<script>
  function setBulkAction(action) {
    document.getElementById('bulk-action-type').value = action;
    document.forms[0].submit();
  }
</script>

