<!-- File: views/articles/list.ejs -->
<h2><%= title %></h2>

<a href="/admin/articles/new">Add Article</a>
<a href="/admin/export/articles/csv">Export Articles (CSV)</a>
<form method="GET" action="/admin/articles">
  <input type="text" name="q" placeholder="Search title..." value="<%= filters.q %>">
  <select name="status">
    <option value="">All Status</option>
    <option value="draft" <%= filters.status === 'draft' ? 'selected' : '' %>>Draft</option>
    <option value="published" <%= filters.status === 'published' ? 'selected' : '' %>>Published</option>
  </select>
  <select name="categoryId">
    <option value="">All Categories</option>
    <% categories.forEach(cat => { %>
      <option value="<%= cat.id %>" <%= filters.categoryId == cat.id ? 'selected' : '' %>><%= cat.name %></option>
    <% }) %>
  </select>
  <select name="subCategoryId">
    <option value="">All Sub-Categories</option>
    <% subcategories.forEach(sub => { %>
      <option value="<%= sub.id %>" <%= filters.subCategoryId == sub.id ? 'selected' : '' %>><%= sub.name %></option>
    <% }) %>
  </select>
  <button type="submit">Filter</button>
</form>
