<!-- File: views/articles/list.ejs -->
<div class="flex justify-between items-center mb-6">
  <h2 class="text-3xl font-bold text-gray-800"><%= title %></h2>
  <div class="flex gap-3">
    <a href="/admin/export/articles/csv" class="btn-secondary">
      <svg class="w-5 h-5 inline-block mr-2 -mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      Export CSV
    </a>
    <a href="/admin/articles/new" class="btn-primary">
      <svg class="w-5 h-5 inline-block mr-2 -mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
      </svg>
      Add Article
    </a>
    <a href="/admin/articles/bulk-upload" class="btn-primary">
    <svg
      class="w-5 h-5 inline-block"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 4v16m8-8H4"
      ></path>
    </svg>
    Bulk Upload
  </a>
  </div>
</div>

<!-- Filter Section -->
<div class="bg-white rounded-2xl shadow-lg p-6 mb-6 border border-gray-200">
  <h3 class="text-lg font-semibold text-gray-800 mb-4">Filters</h3>
  <form method="GET" action="/admin/articles">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-4 mb-4">
      <input 
        type="text" 
        name="q" 
        placeholder="Search title..." 
        value="<%= filters.q %>"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
      />
      <select 
        name="status"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
      >
        <option value="">All Status</option>
        <option value="Draft" <%= filters.status === 'Draft' ? 'selected' : '' %>>Draft</option>
        <option value="Active" <%= filters.status === 'Active' ? 'selected' : '' %>>Active</option>
        <option value="InActive" <%= filters.status === 'InActive' ? 'selected' : '' %>>InActive</option>
      </select>
      <select 
        name="categoryId"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
      >
        <option value="">All Categories</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>" <%= filters.categoryId == cat.id ? 'selected' : '' %>><%= cat.name %></option>
        <% }) %>
      </select>

      <select 
        name="subCategoryId"
        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none"
      >
 <option value="">All Sub-Categories</option>
        <% subcategories.forEach(sub => { %>
          <option value="<%= sub.id %>" <%= filters.subCategoryId == sub.id ? 'selected' : '' %>><%= sub.name %></option>
        <% }) %>
      </select>
      <button type="submit" class="btn-primary">
        <svg class="w-5 h-5 inline-block mr-2 -mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        Filter
      </button>

    </div>
  </div>

  <!-- Stats Cards -->
  <div class="stats-mini-grid">
    <div class="stat-mini-card">
      <div class="stat-mini-icon stat-mini-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
        </svg>
      </div>
      <div class="stat-mini-content">
        <span class="stat-mini-label">Total Articles</span>
        <span class="stat-mini-value"><%= articles?.length || 0 %></span>
      </div>
    </div>
    <div class="stat-mini-card">
      <div class="stat-mini-icon stat-mini-green">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <div class="stat-mini-content">
        <span class="stat-mini-label">Active</span>
        <span class="stat-mini-value"><%= articles?.filter(a => a.status === 'Active').length || 0 %></span>
      </div>
    </div>
    <div class="stat-mini-card">
      <div class="stat-mini-icon stat-mini-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 20h9"></path>
          <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
        </svg>
      </div>
      <div class="stat-mini-content">
        <span class="stat-mini-label">Draft</span>
        <span class="stat-mini-value"><%= articles?.filter(a => a.status === 'Draft').length || 0 %></span>
      </div>
    </div>
  </div>

  <!-- Advanced Filters Card -->
  <div class="filters-card">
    <div class="filters-header">
      <h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
        </svg>
        Advanced Filters
      </h3>
    </div>
    <form method="GET" action="/admin/articles" class="filters-form">
      <div class="filters-grid">
        <div class="filter-input-group">
          <label>Search Title</label>
          <div class="search-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input type="text" name="q" placeholder="Search by title..." value="<%= filters.q %>" />
          </div>
        </div>

        <div class="filter-input-group">
          <label>Status</label>
          <select name="status" class="filter-dropdown">
            <option value="">All Status</option>
            <option value="Draft" <%= filters.status === 'Draft' ? 'selected' : '' %>>Draft</option>
            <option value="Active" <%= filters.status === 'Active' ? 'selected' : '' %>>Active</option>
            <option value="InActive" <%= filters.status === 'InActive' ? 'selected' : '' %>>InActive</option>
          </select>
        </div>

        <div class="filter-input-group">
          <label>Category</label>
          <select name="categoryId" class="filter-dropdown">
            <option value="">All Categories</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat.id %>" <%= filters.categoryId == cat.id ? 'selected' : '' %>><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="filter-input-group">
          <label>Sub-Category</label>
          <select name="subCategoryId" class="filter-dropdown">
            <option value="">All Sub-Categories</option>
            <% subcategories.forEach(sub => { %>
              <option value="<%= sub.id %>" <%= filters.subCategoryId == sub.id ? 'selected' : '' %>><%= sub.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="filter-input-group">
          <button type="submit" class="action-btn action-btn-primary" style="margin-top: 24px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
            Apply Filters
          </button>
        </div>
      </div>
    </form>
  </div>

  <!-- Table Card -->
  <div class="table-card">
    <div class="table-card-header">
      <div class="table-card-title">
        <h3>All Articles</h3>
        <span class="table-card-count"><%= articles?.length || 0 %> total</span>
      </div>
    </div>

    <div class="table-wrapper">
      <table class="modern-table">
        <thead>
          <tr>
            <th class="checkbox-col">
              <label class="custom-checkbox">
                <input type="checkbox" id="selectAll" />
                <span class="checkmark"></span>
              </label>
            </th>
            <th class="sortable">
              Article Name
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="7 10 12 15 17 10"></polyline>
                <polyline points="7 14 12 9 17 14"></polyline>
              </svg>
            </th>
            <th>Category</th>
            <th>Sub-Category</th>
            <th class="sortable">
              Status
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="7 10 12 15 17 10"></polyline>
                <polyline points="7 14 12 9 17 14"></polyline>
              </svg>
            </th>
            <th class="action-col">Actions</th>
          </tr>
        </thead>
        <tbody id="categoryTableBody">
          <% if (articles && articles.length > 0) { %>
            <% articles.forEach((article, index) => { %>
            <tr class="table-row" style="animation-delay: <%= index * 0.05 %>s">
              <td class="checkbox-col">
                <label class="custom-checkbox">
                  <input type="checkbox" class="row-checkbox" />
                  <span class="checkmark"></span>
                </label>
              </td>
              <td class="category-name-col">
                <div class="category-info">
                  <div class="category-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                  </div>
                  <span class="category-name"><%= article.name %></span>
                </div>
              </td>
              <td>
                <span class="parent-category-badge"><%= article.Category?.name || 'N/A' %></span>
              </td>
              <td>
                <span class="parent-category-badge"><%= article.SubCategory?.name || 'N/A' %></span>
              </td>
              <td>
                <% if (article.status === 'Active') { %>
                  <span class="status-badge status-active">
                    <span class="status-dot"></span>
                    Active
                  </span>
                <% } else if (article.status === 'InActive') { %>
                  <span class="status-badge status-inactive">
                    <span class="status-dot"></span>
                    InActive
                  </span>
                <% } else { %>
                  <span class="status-badge status-draft">
                    <span class="status-dot"></span>
                    Draft
                  </span>
                <% } %>
              </td>
              <td class="action-col">
                <div class="action-buttons">
                  <a href="/admin/articles/edit/<%= article.id %>" class="btn-icon btn-edit" title="Edit">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 20h9"></path>
                      <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
                    </svg>
                  </a>
                  <form method="POST" action="/admin/articles/toggle-status/<%= article.id %>" class="inline-form">
                    <button type="submit" class="btn-icon btn-toggle" title="Toggle Status">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M12 1v6m0 6v6"></path>
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="6" class="empty-state">
                <div class="empty-state-content">
                  <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                  </svg>
                  <h3>No articles found</h3>
                  <p>Try adjusting your filters or create a new article</p>
                  <a href="/admin/articles/new" class="action-btn action-btn-primary" style="margin-top: 15px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Create First Article
                  </a>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <% if (articles && articles.length > 0 && pagination && pagination.totalPages > 1) { %>
  <div class="pagination-wrapper">
    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <a 
        href="?page=<%= i %>&<%= new URLSearchParams(filters).toString() %>"
        class="pagination-btn <%= i === pagination.page ? 'active' : '' %>"
      >
        <%= i %>
      </a>
    <% } %>
  </div>
  <% } %>
</div>

<script>
  // Select all checkbox
  const selectAll = document.getElementById('selectAll');
  if (selectAll) {
    selectAll.addEventListener('change', function() {
      const checkboxes = document.querySelectorAll('.row-checkbox');
      checkboxes.forEach(cb => cb.checked = this.checked);
    });
  }
</script>
